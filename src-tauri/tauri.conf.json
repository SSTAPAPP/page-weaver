{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:8080",
    "distDir": "../dist"
  },
  "package": {
    "productName": "FFk",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      },
      "process": {
        "relaunch": true
      }
    },
    "updater": {
      "active": false,
      "dialog": false,
      "pubkey": "",
      "endpoints": [
        "https://github.com/SSTAPAPP/page-weaver/releases/latest/download/latest.json"
      ]
    },
    "bundle": {
      "active": true,
      "targets": ["msi"],
      "identifier": "com.ffk.app",
      "icon": [
        "icons/icon.ico",
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png"
      ],
      "windows": {
        "wix": {
          "language": "zh-CN"
        }
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "FFk - 理发店管理系统",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  }
}